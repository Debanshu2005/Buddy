# Database Configuration (Neon PostgreSQL)
DB_HOST=your-neon-host.neon.tech
DB_NAME=your_database_name
DB_USER=your_username
DB_PASSWORD=your_password
DB_PORT=5432

# LLM Service Configuration
LLM_SERVICE_URL=http://192.168.x.x:8000

# Camera Settings (Optional)
BUDDY_CAMERA_INDEX=0
BUDDY_LOG_LEVEL=WARNING

# PC Webcam Stream (set this to your laptop's local IP to use the Zebronics cam over WiFi)
BUDDY_PC_CAMERA_IP=10.142.68.62
BUDDY_PC_CAMERA_PORT=5000
